{
  "name": "cortes",
  "private": true,
  "version": "0.1.0",
  "description": "A living portrait of Cortes Island — photorealistic 3D island with a floating cloud of geolocated news, wildlife, photos and community life.",
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env server/index.js",
    "dev": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "fetch": "node --env-file-if-exists=.env server/cli.js fetch",
    "test": "node --test server/test/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@fastify/static": "^8.0.0",
    "@orbitalfoundation/bus": "^2.0.0",
    "fast-xml-parser": "^5.0.0",
    "fastify": "^5.0.0",
    "mongodb": "^6.10.0",
    "socket.io": "^4.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
