# --- server ---
PORT=8000
MONGO_URL=mongodb://localhost:27017
MONGO_DB=cortes

# Cesium ion token (client fetches it from /api/config). Free at https://ion.cesium.com
CESIUM_KEY=

# Optional: LLM enrichment (geolocation, categorization, importance).
# Without a key the pipeline falls back to the built-in gazetteer + heuristics.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Optional social sources — adapters stay dormant without keys
X_BEARER_TOKEN=

# Aggregation cadence in seconds (0 disables the scheduler)
TICK_SECONDS=900
